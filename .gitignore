# === 비밀 파일 (절대 올리면 안 됨) ===
.env
.env.local
*.key
secrets/
.streamlit/secrets.toml

# .env.example 은 키 없는 견본이라 올려도 됨 (아래 한 줄이 예외 처리)
!.env.example

# === Python 캐시/가상환경 ===
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# === OS / 에디터 부산물 ===
Thumbs.db
.DS_Store
*.swp
.idea/
.vscode/

# === 앱 실행 로그 ===
*.log
.streamlit_run.log

# === 데이터 (Google 공유 드라이브가 단일 소스 — git 추적 제외) ===
# data 폴더는 정션으로 공유 드라이브에 연결됨. 버전관리는 Drive 파일 기록 사용.
data/
